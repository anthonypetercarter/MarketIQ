// -----------------------------------------------------------------------------
// MarketIQ — Prisma Schema
//
// This schema is a direct translation of the domain model agreed on with the
// founder before any tables were designed. Field and enum names intentionally
// mirror product language (e.g. CouncilRecommendation values, "Defensive"
// rather than "Bearish", "Increase Equity Allocation" rather than "Increase
// Risk Exposure") so the schema stays legible as a product artifact, not
// just a storage layer.
// -----------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum CouncilRole {
  CHIEF_MARKET_OFFICER
  CHIEF_SECTOR_STRATEGIST
  CHIEF_COMPANY_ANALYST
  CHIEF_TECHNICAL_STRATEGIST
  CHIEF_RISK_OFFICER
  CHIEF_SCIENTIST
  CHIEF_CLIENT_OFFICER
  CHIEF_GOVERNANCE_OFFICER
  CHIEF_INVESTMENT_OFFICER
}

enum MarketOutlook {
  STRONGLY_BULLISH
  MODERATELY_BULLISH
  NEUTRAL
  CAUTIOUS
  DEFENSIVE
}

/// Investor-friendly headline recommendation. Deliberately about capital
/// allocation, not individual securities — company-specific calls live in
/// Opportunity and RecommendedAction instead.
enum CouncilRecommendation {
  INCREASE_EQUITY_ALLOCATION
  MAINTAIN_CURRENT_ALLOCATION
  REDUCE_EQUITY_ALLOCATION
}

enum ActionType {
  BUY
  REDUCE
  HOLD
  WATCH
  REBALANCE
}

/// Each executive's up-or-down stance on the Brief's headline recommendation.
enum CouncilVerdict {
  SUPPORT
  SUPPORT_WITH_RESERVATIONS
  NEUTRAL
  OPPOSE
}

/// Sprint 2: distinguishes Domestic vs International equity holdings so the
/// Portfolio page can compare actual allocation against the Brief's
/// AllocationTarget categories. Bonds/Alternatives aren't modeled as real
/// holdings yet — see docs/decisions.md.
enum CompanyRegion {
  DOMESTIC
  INTERNATIONAL
}

/// A real CIO's toolkit isn't limited to single stocks — funds carry
/// fundamentally different risk (diversified vs. one company's
/// idiosyncratic risk), which is why this is a first-class distinction
/// rather than folding funds into Company unchanged. See docs/decisions.md.
enum AssetType {
  EQUITY
  FUND
}

// -----------------------------------------------------------------------------
// Core entities
// -----------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  portfolio Portfolio?
  briefs    Brief[]

  @@map("users")
}

model Portfolio {
  id           String   @id @default(cuid())
  userId       String   @unique
  cashBalance  Decimal  @default(0) @db.Decimal(18, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings Holding[]
  reviews  PortfolioReview[]

  @@map("portfolios")
}

model Holding {
  id          String   @id @default(cuid())
  portfolioId String
  companyId   String
  quantity    Decimal  @db.Decimal(18, 4)
  costBasis   Decimal  @db.Decimal(18, 4) // average cost per share (mocked for V1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id])

  @@unique([portfolioId, companyId])
  @@map("holdings")
}

model Company {
  id     String @id @default(cuid())
  ticker String @unique
  name   String
  /// For assetType=FUND, use an honest value like "Diversified" rather than
  /// forcing a single industry — Sector Exposure groups by this value
  /// as-is, so a fund correctly gets its own bucket without any special
  /// handling, as long as it isn't given a misleading single-sector label.
  sector String

  /// Sprint 2 additions — mocked for now, same spirit as the Council's
  /// mocked assessments. currentPrice/previousClosePrice power the
  /// Portfolio Summary's Total Value and Today's Change; region powers the
  /// equity allocation comparison (Domestic vs International).
  currentPrice       Decimal       @db.Decimal(18, 4)
  previousClosePrice Decimal       @db.Decimal(18, 4)
  region             CompanyRegion
  /// EQUITY for single companies, FUND for ETFs/index funds — changes the
  /// concentration ceiling applied and the evidence standard the Council
  /// holds a candidate to. Defaults to EQUITY for every pre-existing row.
  assetType          AssetType     @default(EQUITY)
  /// SEC's real Central Index Key, cached once looked up (decision #11) —
  /// a CIK never changes, so caching avoids re-fetching SEC's large,
  /// shared ticker-mapping file on every Portfolio Review. Null for a
  /// fund or any company EDGAR has never successfully resolved.
  cik                String?

  holdings           Holding[]
  opportunities      Opportunity[]
  recommendedActions RecommendedAction[]

  @@map("companies")
}

// -----------------------------------------------------------------------------
// The MarketIQ Brief and everything it's composed of
// -----------------------------------------------------------------------------

model Brief {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date

  /// One or two sentences powering the "Today's Decision" section — the
  /// under-30-seconds summary at the top of the Brief. Distinct from
  /// executiveSummary, which is the fuller Council Summary narrative.
  decisionRationale String @db.Text

  executiveSummary              String                @db.Text
  councilRecommendation         CouncilRecommendation
  councilConfidence             Int // 0-100; label (Low/Medium/High/Very High) derived at render time
  marketOutlook                 MarketOutlook
  historicalSimilarityNarrative String                @db.Text // mocked free text for V1

  preparedBy String @default("MarketIQ Investment Council")
  approvedBy String @default("Chief Investment Officer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  councilAssessments CouncilAssessment[]
  risks              Risk[]
  opportunities      Opportunity[]
  recommendedActions RecommendedAction[]
  allocationTargets  AllocationTarget[]
  portfolioReviews   PortfolioReview[]

  @@unique([userId, date])
  @@map("briefs")
}

/// One row per council role per Brief (9 total: 8 members + CIO).
/// This is each executive's decision journal entry for that day.
model CouncilAssessment {
  id      String      @id @default(cuid())
  briefId String
  role    CouncilRole

  opinion         String         @db.Text
  confidenceScore Int // 0-100
  rationale       String         @db.Text
  risksNoted      String         @db.Text // this executive's raw risk observations
  changeTrigger   String         @db.Text // "what would change my opinion"
  verdict         CouncilVerdict

  createdAt DateTime @default(now())

  brief            Brief  @relation(fields: [briefId], references: [id], onDelete: Cascade)
  synthesizedRisks Risk[] @relation("RiskSourceAssessments")

  @@unique([briefId, role])
  @@map("council_assessments")
}

/// A CIO-synthesized Primary Risk. Always traceable to at least one
/// CouncilAssessment — the CIO synthesizes Risks from what the council
/// reported, but does not originate independent risks.
model Risk {
  id          String @id @default(cuid())
  briefId     String
  title       String
  description String @db.Text

  brief             Brief               @relation(fields: [briefId], references: [id], onDelete: Cascade)
  sourceAssessments CouncilAssessment[] @relation("RiskSourceAssessments")

  @@map("risks")
}

/// Either company-specific (companyId set) or thematic (thematicTitle set).
/// Exactly one of the two must be set — enforced in the application layer,
/// since a portable CHECK constraint isn't expressible for this XOR shape.
model Opportunity {
  id            String  @id @default(cuid())
  briefId       String
  thesis        String  @db.Text
  conviction    Int // 0-100
  companyId     String?
  thematicTitle String?

  brief   Brief    @relation(fields: [briefId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])

  @@map("opportunities")
}

/// A discrete, potentially executable action tied to a Brief. The action
/// with the lowest displayOrder is treated as the "immediate action" shown
/// in the Today's Decision section, rather than duplicating that text.
model RecommendedAction {
  id           String     @id @default(cuid())
  briefId      String
  description  String     @db.Text
  actionType   ActionType
  displayOrder Int
  companyId    String?

  brief   Brief    @relation(fields: [briefId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])

  @@map("recommended_actions")
}

/// Explicit recommended capital allocation split for a Brief
/// (e.g. "US Equities" -> 55.00, "Cash" -> 10.00).
model AllocationTarget {
  id            String  @id @default(cuid())
  briefId       String
  category      String
  targetPercent Decimal @db.Decimal(5, 2)

  brief Brief @relation(fields: [briefId], references: [id], onDelete: Cascade)

  @@unique([briefId, category])
  @@map("allocation_targets")
}

// -----------------------------------------------------------------------------
// Portfolio Review — North Star Vision (docs/decisions.md)
// -----------------------------------------------------------------------------

/// Investment verdict on a single holding, per North Star Vision: the Council
/// forms an independent judgment, not a rule-derived label.
enum HoldingVerdict {
  BUY
  INCREASE
  HOLD
  REDUCE
  EXIT
}

/// The Council's daily portfolio judgment — generated once each real morning
/// by a single AI call reviewing the whole portfolio together (not one
/// holding in isolation), then published and read on every subsequent page
/// load rather than regenerated. References the day's Brief for evidence
/// traceability, but is portfolio-specific — the Brief itself stays
/// portfolio-agnostic, unchanged (see decision #4's Dashboard/Brief/Portfolio
/// separation, still intact).
///
/// Deliberately minimal: one JSON column for the per-holding verdicts,
/// not a child table per verdict. If a real future need arises to query
/// across days (e.g. "every day AAPL got an EXIT verdict"), that's the
/// trigger to normalize this further — not before.
model PortfolioReview {
  id          String   @id @default(cuid())
  portfolioId String
  briefId     String
  date        DateTime @db.Date
  generatedAt DateTime @default(now())

  /// The "minutes of the meeting" — a short narrative capturing the
  /// committee's overall discussion, distinct from the verdicts below.
  /// The verdicts are the conclusion; this is the discussion that led there.
  narrative String @db.Text

  /// { existingHoldings: [{ticker, companyName, verdict, evidence[]}],
  ///   newPositions: [{ticker, companyName, verdict:"BUY", evidence[], trade}] }.
  /// existingHoldings has exactly one entry per real holding — a verdict
  /// that fails validation degrades to a safe HOLD for that holding alone,
  /// never invalidates the batch. newPositions is zero or more Council-
  /// approved BUYs on currently-unheld candidates from that day's Brief,
  /// sized against a shared Excess Cash pool — see
  /// src/lib/council/validatePortfolioReview.ts and
  /// src/lib/portfolio/playbook.ts's sizeNewPositionBuys.
  verdicts Json

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  brief     Brief     @relation(fields: [briefId], references: [id])

  @@unique([portfolioId, date])
  @@map("portfolio_reviews")
}
