# -----------------------------------------------------------------------------
# MarketIQ — Environment Variables
# Copy this file to .env and fill in real values. .env is gitignored.
# -----------------------------------------------------------------------------

# Postgres credentials — consumed directly by docker-compose.yml to configure
# the local Postgres container. Change these if you need non-default values.
POSTGRES_USER="marketiq"
POSTGRES_PASSWORD="marketiq"
POSTGRES_DB="marketiq"
POSTGRES_PORT="5432"

# Postgres connection string used by Prisma. Must stay in sync with the
# POSTGRES_* values above — see docker-compose.yml for the running service.
DATABASE_URL="postgresql://marketiq:marketiq@localhost:5432/marketiq?schema=public"

# Display name used on the Dashboard greeting ("Good Morning, {APP_USER_NAME}").
# Sprint 1 uses a single hardcoded user — no real auth yet.
APP_USER_NAME="Anthony"

# Public-facing app name, safe to expose to the browser.
NEXT_PUBLIC_APP_NAME="MarketIQ"

# -----------------------------------------------------------------------------
# Market Data (docs/decisions.md #5 — Milestone 1)
# -----------------------------------------------------------------------------

# Alpaca Markets — free paper trading account, sign up at https://alpaca.markets
# Keys are in your dashboard once logged in. Data API works the same on the
# free tier for both paper and live accounts (IEX feed, sufficient for daily
# pricing — see src/lib/marketdata/alpaca.ts for what we use it for).
ALPACA_API_KEY_ID=""
ALPACA_API_SECRET_KEY=""
# Leave as-is unless Alpaca's data API base URL changes.
ALPACA_DATA_BASE_URL="https://data.alpaca.markets"
# Paper trading API — same keys as above. Used read-only (see
# src/lib/marketdata/alpacaTrading.ts): syncs your real paper account's
# positions and cash balance into Portfolio/Holding. Never places trades.
ALPACA_TRADING_BASE_URL="https://paper-api.alpaca.markets"

# FRED (Federal Reserve Economic Data) — free API key, sign up at
# https://fred.stlouisfed.org (Account -> API Keys). Used for macro context
# (yield curve, Fed funds rate) — see src/lib/marketdata/fred.ts.
FRED_API_KEY=""

# -----------------------------------------------------------------------------
# Portfolio Review (North Star Vision, docs/decisions.md)
# -----------------------------------------------------------------------------

# Anthropic API key — used by the Council's single daily call reviewing the
# whole portfolio. Get one at https://console.anthropic.com (API Keys).
ANTHROPIC_API_KEY=""
# Optional override — leave commented out to use the default (currently
# claude-sonnet-5). See src/lib/council/generatePortfolioReview.ts.
# PORTFOLIO_REVIEW_MODEL="claude-sonnet-5"
